# Optional local-only Gemini key for testing tavern/POI conversation.
# Production browser builds do not inline this key unless client LLM mode is
# deliberately enabled for development in vite.config.ts.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
VITE_ENABLE_CLIENT_LLM="false"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
